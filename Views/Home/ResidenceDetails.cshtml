
@{
    string residence = ViewBag.Residence ?? "single";
    string userType = Context.Session.GetString("UserType") ?? "demo";
    string residenceName = residence switch
    {
        "single" => "The Single",
        "double" => "The Double",
        "triple" => "The Triple",
        "mix" => "The Mix",
        _ => "The Single"
    };

    string description = residence switch
    {
        "single" => "Perfect for students who value privacy and quiet study time. Each room features a comfortable single bed, study desk, wardrobe, and air conditioning.",
        "double" => "Ideal for friends who want to share space. Each room includes two beds, two study desks, shared wardrobe, and air conditioning.",
        "triple" => "Great for social students who enjoy community living. Spacious rooms with three beds, common area, and ceiling fans.",
        "mix" => "The best of all worlds! Choose from single, double, or triple rooms in one residence. Perfect for friend groups.",
        _ => "Perfect for students who value privacy and quiet study time."
    };

    // Determine the image number suffix based on residence
    string imageSuffix = residence switch
    {
        "single" => "1",
        "double" => "2",
        "triple" => "3",
        _ => "1" // Default to 1 for mix (though mix will use Unsplash)
    };

    var rooms = ViewBag.Rooms as List<ThePleasantOcc.Models.Room>;
    int totalBeds = ViewBag.TotalBeds ?? 0;
    int availableBeds = ViewBag.AvailableBeds ?? 0;
    int occupiedBeds = ViewBag.OccupiedBeds ?? 0;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@residenceName - ThePleasantOcc</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        :root {
            --primary-blue: #1e3a8a;
            --secondary-blue: #2563eb;
            --light-blue: #3b82f6;
            --cool-grey: #64748b;
            --light-grey: #94a3b8;
            --soft-grey: #e2e8f0;
            --dark-grey: #334155;
            --white: #ffffff;
            --black: #0f172a;
            --success-green: #10b981;
            --danger-red: #ef4444;
        }

        body {
            background-color: #f8fafc;
            color: var(--dark-grey);
            font-family: 'Inter', sans-serif;
        }

        h1, h2, h3, h4, h5, h6 {
            color: var(--primary-blue);
            font-weight: 700;
        }

        /* Navigation */
        .navbar-modern {
            background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%) !important;
            box-shadow: 0 4px 20px rgba(30, 58, 138, 0.2);
            padding: 15px 0;
        }

            .navbar-modern .navbar-brand {
                color: white !important;
                font-weight: 700;
                font-size: 1.8rem;
            }

            .navbar-modern .nav-link {
                color: rgba(255,255,255,0.9) !important;
                font-weight: 500;
                margin: 0 15px;
            }

        /* Hero Section */
        .detail-hero {
            padding: 120px 0 60px;
            background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
        }

            .detail-hero h1 {
                font-size: 3rem;
                font-weight: 800;
            }

        .badge-available {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            padding: 8px 20px;
            border-radius: 50px;
            font-weight: 600;
            display: inline-block;
        }

        .badge-full {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: white;
            padding: 8px 20px;
            border-radius: 50px;
            font-weight: 600;
        }

        /* Main Image */
        .main-image {
            width: 100%;
            height: 400px;
            object-fit: cover;
            border-radius: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        /* Gallery Images */
        .gallery-img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            border-radius: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 3px solid transparent;
        }

            .gallery-img:hover {
                transform: scale(1.05);
                border-color: var(--secondary-blue);
                box-shadow: 0 10px 25px rgba(37, 99, 235, 0.3);
            }

        /* Feature Cards */
        .feature-card {
            background: white;
            border-radius: 20px;
            padding: 25px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            height: 100%;
        }

            .feature-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 20px 40px rgba(37, 99, 235, 0.15);
            }

        .feature-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.1), rgba(30, 58, 138, 0.1));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: var(--primary-blue);
            margin: 0 auto 20px;
        }

        /* Room Cards */
        .room-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            border: 1px solid var(--soft-grey);
            height: 100%;
            position: relative;
        }

            .room-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(37, 99, 235, 0.15);
                border-color: var(--secondary-blue);
            }

        .room-number {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--primary-blue);
        }

        .room-status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .status-available {
            background: #d1fae5;
            color: #065f46;
        }

        .status-partial {
            background: #fff3cd;
            color: #856404;
        }

        .status-occupied {
            background: #fee2e2;
            color: #991b1b;
        }

        .btn-occupy {
            background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 50px;
            font-weight: 500;
            width: 100%;
            transition: all 0.3s ease;
        }

            .btn-occupy:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(37, 99, 235, 0.4);
                color: white;
            }

            .btn-occupy:disabled {
                background: var(--light-grey);
                opacity: 0.5;
                cursor: not-allowed;
            }

        /* Stats Card */
        .stats-card {
            background: white;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        .stat-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid var(--soft-grey);
        }

            .stat-item:last-child {
                border-bottom: none;
            }

        .stat-label {
            color: var(--cool-grey);
            font-weight: 500;
        }

        .stat-value {
            font-weight: 700;
            color: var(--primary-blue);
            font-size: 1.2rem;
        }

        /* Back Button */
        .btn-back {
            background: transparent;
            border: 2px solid var(--secondary-blue);
            color: var(--secondary-blue);
            padding: 10px 25px;
            border-radius: 50px;
            font-weight: 500;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

            .btn-back:hover {
                background: var(--secondary-blue);
                color: white;
                transform: translateX(-5px);
            }

        /* Section Title */
        .section-title {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary-blue);
            margin-bottom: 30px;
            position: relative;
        }

            .section-title::after {
                content: '';
                position: absolute;
                bottom: -10px;
                left: 0;
                width: 60px;
                height: 4px;
                background: linear-gradient(90deg, var(--primary-blue), var(--secondary-blue));
                border-radius: 2px;
            }

        /* Modal Styles */
        .modal-content {
            border-radius: 20px;
            border: none;
        }

        .modal-header {
            background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
            color: white;
            border-radius: 20px 20px 0 0;
        }

            .modal-header .btn-close {
                filter: brightness(0) invert(1);
            }

        .modal-footer {
            border-top: 1px solid var(--soft-grey);
        }
    </style>
</head>
<body>

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-modern fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-building me-2"></i>ThePleasantOcc
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/#home">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#residences">Residences</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#amenities">Amenities</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/#contact">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="detail-hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <a href="/Home/Index#residences" class="btn-back mb-4">
                        <i class="fas fa-arrow-left me-2"></i>Back to Residences
                    </a>
                    <h1 data-aos="fade-right">@residenceName</h1>
                    <p class="fs-5 text-secondary mb-4" data-aos="fade-right" data-aos-delay="100">@description</p>

                    <div class="d-flex gap-3 mb-4" data-aos="fade-right" data-aos-delay="200">
                        @if (availableBeds > 0)
                        {
                            <span class="badge-available"><i class="fas fa-check-circle me-2"></i>@availableBeds of @totalBeds Beds Available</span>
                        }
                        else
                        {
                            <span class="badge-full"><i class="fas fa-times-circle me-2"></i>Fully Occupied</span>
                        }
                        <span class="badge bg-primary bg-opacity-10 text-primary p-2 rounded-4">
                            <i class="fas fa-door-open me-2"></i>@(string.Join("/", ViewBag.RoomTypes ?? new[] { "Single" })) Rooms
                        </span>
                    </div>
                </div>
                <div class="col-lg-4 text-lg-end" data-aos="fade-left">
                    <div class="stats-card">
                        <h5 class="mb-3">Quick Stats</h5>
                        <div class="stat-item">
                            <span class="stat-label"><i class="fas fa-bed me-2 text-primary"></i>Total Beds</span>
                            <span class="stat-value" id="totalBeds">@totalBeds</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-label"><i class="fas fa-check-circle me-2 text-success"></i>Available</span>
                            <span class="stat-value text-success" id="availableBeds">@availableBeds</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-label"><i class="fas fa-times-circle me-2 text-danger"></i>Occupied</span>
                            <span class="stat-value text-danger" id="occupiedBeds">@occupiedBeds</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-label"><i class="fas fa-layer-group me-2 text-primary"></i>Floors</span>
                            <span class="stat-value">4</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Image Section -->
    <section class="py-4">
        <div class="container">
            <div class="row">
                <div class="col-12" data-aos="fade-up">
                    <img src="~/images/IMG_@(residence switch
                         {
                             "single" => "3851",
                             "double" => "3849",
                             "triple" => "3853",
                             "mix" => "3850",
                             _ => "3851"
                         }).JPG"
                         alt="@residenceName" class="main-image">
                </div>
            </div>
        </div>
    </section>

    <!-- Gallery Section - DYNAMIC with numbers 1,2,3 for Single, Double, Triple -->
    <section class="py-4">
        <div class="container">
            <h2 class="section-title" data-aos="fade-right">Residence Gallery</h2>
            <div class="row g-3">
                @if (residence == "mix")
                {
                    <!-- Mix Residence - Use Unsplash images -->
                    <!-- Actual Room -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="100">
                        <img src="https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?w=400" alt="Actual Room" class="gallery-img">
                        <p class="text-center mt-2"><i class="fas fa-bed me-2 text-primary"></i>Actual Room</p>
                    </div>
                    <!-- Kitchen -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="200">
                        <img src="~/images/Kitchen4.JPG" alt="Kitchen" class="gallery-img">
                        <p class="text-center mt-2"><i class="fas fa-utensils me-2 text-primary"></i>Kitchen</p>
                    </div>
                    <!-- Bathroom -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="300">
                        <img src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?w=400" alt="Bathroom" class="gallery-img">
                        <p class="text-center mt-2"><i class="fas fa-shower me-2 text-primary"></i>Bathroom</p>
                    </div>
                    <!-- Gym -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="400">
                        <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=400" alt="Gym" class="gallery-img">
                        <p class="text-center mt-2"><i class="fas fa-dumbbell me-2 text-primary"></i>Gym</p>
                    </div>
                    <!-- Pool -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="500">
                        <img src="https://images.unsplash.com/photo-1576013551627-0cc20b96c2a7?w=400" alt="Pool" class="gallery-img">
                        <p class="text-center mt-2"><i class="fas fa-swimmer me-2 text-primary"></i>Pool</p>
                    </div>
                    <!-- Park -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="600">
                        <img src="https://images.unsplash.com/photo-1519331379826-f10be5486c6f?w=400" alt="Park" class="gallery-img">
                        <p class="text-center mt-2"><i class="fas fa-tree me-2 text-primary"></i>Park</p>
                    </div>
                }
                else
                {
                    <!-- Single, Double, Triple - Use images with numbers 1,2,3 -->
                    <!-- Actual Room -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="100">
                        <img src="~/images/Room@(imageSuffix).JPG" alt="Actual Room" class="gallery-img" onerror="this.src='https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?w=400'">
                        <p class="text-center mt-2"><i class="fas fa-bed me-2 text-primary"></i>Actual Room</p>
                    </div>
                    <!-- Kitchen -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="200">
                        <img src="~/images/Kitchen@(imageSuffix).JPG" alt="Kitchen" class="gallery-img" onerror="this.src='https://images.unsplash.com/photo-1556911220-bff5a9c5a8b5?w=400'">
                        <p class="text-center mt-2"><i class="fas fa-utensils me-2 text-primary"></i>Kitchen</p>
                    </div>
                    <!-- Bathroom -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="300">
                        <img src="~/images/Bathroom@(imageSuffix).JPG" alt="Bathroom" class="gallery-img" onerror="this.src='https://images.unsplash.com/photo-1584622650111-993a426fbf0a?w=400'">
                        <p class="text-center mt-2"><i class="fas fa-shower me-2 text-primary"></i>Bathroom</p>
                    </div>
                    <!-- Gym -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="400">
                        <img src="~/images/Gym@(imageSuffix).JPG" alt="Gym" class="gallery-img" onerror="this.src='https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=400'">
                        <p class="text-center mt-2"><i class="fas fa-dumbbell me-2 text-primary"></i>Gym</p>
                    </div>
                    <!-- Pool - Always Unsplash -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="500">
                        <img src="https://images.unsplash.com/photo-1576013551627-0cc20b96c2a7?w=400" alt="Pool" class="gallery-img">
                        <p class="text-center mt-2"><i class="fas fa-swimmer me-2 text-primary"></i>Pool</p>
                    </div>
                    <!-- Park -->
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="600">
                        <img src="~/images/Park@(imageSuffix).JPG" alt="Park" class="gallery-img" onerror="this.src='https://images.unsplash.com/photo-1519331379826-f10be5486c6f?w=400'">
                        <p class="text-center mt-2"><i class="fas fa-tree me-2 text-primary"></i>Park</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Available Rooms Section - WITH PARTIAL OCCUPANCY -->
    <section class="py-4">
        <div class="container">
            <h2 class="section-title" data-aos="fade-right">Available Rooms</h2>

            @if (rooms != null && rooms.Any(r => r.AvailableBeds > 0))
            {
                <div class="row g-3" id="rooms-container">
                    @{
                        var availableRoomsList = rooms.Where(r => r.AvailableBeds > 0).ToList();
                        int roomsToShow = Math.Min(availableRoomsList.Count, 8);
                    }

                    @for (int i = 0; i < roomsToShow; i++)
                    {
                        var room = availableRoomsList[i];
                        int bedsLeft = room.AvailableBeds;
                        <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="@((i + 1) * 50)">
                            <div class="room-card" id="room-@room.Id" data-total-beds="@room.TotalBeds">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="room-number">Room @room.RoomNumber</span>
                                    @if (bedsLeft == room.TotalBeds)
                                    {
                                        <span class="room-status status-available">
                                            <i class="fas fa-bed me-1"></i>@bedsLeft beds
                                        </span>
                                    }
                                    else if (bedsLeft > 0)
                                    {
                                        <span class="room-status status-partial">
                                            <i class="fas fa-bed me-1"></i>@bedsLeft left
                                        </span>
                                    }
                                </div>
                                <div class="mb-2">
                                    <small class="text-secondary d-block">
                                        <i class="fas fa-bed me-1"></i> @room.RoomType Room
                                    </small>
                                    <small class="text-secondary d-block">
                                        <i class="fas fa-layer-group me-1"></i> Floor @room.Floor
                                    </small>
                                    <small class="text-secondary d-block">
                                        <i class="fas fa-ruler me-1"></i> @room.Size
                                    </small>
                                    <small class="text-secondary d-block">
                                        <i class="fas fa-money-bill me-1"></i> R@(room.Price)/month
                                    </small>
                                </div>
                                @if (bedsLeft > 0)
                                {
                                    if (userType == "student")
                                    {
                                        <button class="btn-occupy" onclick="showBookingForm(@room.Id, '@room.RoomNumber', @bedsLeft)">
                                            <i class="fas fa-check-circle me-2"></i>Occupy Bed (@bedsLeft left)
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn-occupy" disabled style="background: var(--light-grey); cursor: not-allowed; opacity: 0.6;">
                                            <i class="fas fa-ban me-2"></i>Students Only
                                        </button>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (availableRoomsList.Count > 8)
                {
                    <div class="text-center mt-4">
                        <p class="text-secondary">
                            <i class="fas fa-info-circle me-2 text-primary"></i>
                            Showing 8 of @availableRoomsList.Count available rooms.
                            <a href="#" id="view-all-rooms" class="text-primary">View all rooms →</a>
                        </p>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-door-open fa-4x text-muted mb-3"></i>
                    <h4>No Rooms Available</h4>
                    <p class="text-secondary">All rooms in @residenceName are currently occupied. Check back later!</p>
                </div>
            }
        </div>
    </section>

    <!-- Amenities Section -->
    <section class="py-4">
        <div class="container">
            <h2 class="section-title" data-aos="fade-right">Residence Amenities</h2>
            <div class="row g-3">
                <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-wifi"></i>
                        </div>
                        <h6>Free WiFi</h6>
                        <small class="text-secondary">100Mbps</small>
                    </div>
                </div>
                <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-utensils"></i>
                        </div>
                        <h6>3 Kitchens</h6>
                        <small class="text-secondary">Per floor</small>
                    </div>
                </div>
                <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-shower"></i>
                        </div>
                        <h6>4 Bathrooms</h6>
                        <small class="text-secondary">Per floor</small>
                    </div>
                </div>
                <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="400">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-snowflake"></i>
                        </div>
                        <h6>Air Conditioning</h6>
                        <small class="text-secondary">In all rooms</small>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Booking Modal -->
    <div class="modal fade" id="bookingModal" tabindex="-1" aria-labelledby="bookingModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="bookingModalLabel">Occupy Bed in Room <span id="modal-room-number"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="bookingForm">
                        <input type="hidden" id="roomId" name="roomId">
                        <div class="mb-3">
                            <label for="studentName" class="form-label">Full Name</label>
                            <input type="text" class="form-control" id="studentName" required>
                        </div>
                        <div class="mb-3">
                            <label for="studentEmail" class="form-label">Email Address</label>
                            <input type="email" class="form-control" id="studentEmail" required>
                        </div>
                        <div class="mb-3">
                            <label for="studentPhone" class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" id="studentPhone" required>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="submitBooking()" style="background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue)); border: none;">
                        <i class="fas fa-check-circle me-2"></i>Confirm Occupancy
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5 class="text-white"><i class="fas fa-building me-2 text-primary"></i>ThePleasantOcc</h5>
                    <p class="text-secondary">Premium student accommodation in Durban. Live better, study better.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-0"><i class="far fa-copyright me-1"></i>2026 ThePleasantOcc. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            duration: 800,
            once: false,
            mirror: true,
            offset: 50
        });

        // Modal instance
        const bookingModal = new bootstrap.Modal(document.getElementById('bookingModal'));

        // Show booking form
        function showBookingForm(roomId, roomNumber, bedsLeft) {
            document.getElementById('roomId').value = roomId;
            document.getElementById('modal-room-number').textContent = roomNumber + ' (' + bedsLeft + ' bed' + (bedsLeft > 1 ? 's' : '') + ' left)';
            bookingModal.show();
        }

        // Update stats after booking
        function updateStatsAfterBooking() {
            const availableElement = document.getElementById('availableBeds');
            const occupiedElement = document.getElementById('occupiedBeds');

            if (availableElement && occupiedElement) {
                let available = parseInt(availableElement.textContent);
                let occupied = parseInt(occupiedElement.textContent);

                available--;
                occupied++;

                availableElement.textContent = available;
                occupiedElement.textContent = occupied;

                // Update the badge too
                const badge = document.querySelector('.badge-available');
                const totalBeds = document.getElementById('totalBeds').textContent;
                if (badge) {
                    badge.innerHTML = `<i class="fas fa-check-circle me-2"></i>${available} of ${totalBeds} Beds Available`;
                }
            }
        }

        // Submit booking
        function submitBooking() {
            const roomId = document.getElementById('roomId').value;
            const studentName = document.getElementById('studentName').value;
            const studentEmail = document.getElementById('studentEmail').value;
            const studentPhone = document.getElementById('studentPhone').value;

            if (!studentName || !studentEmail || !studentPhone) {
                alert('Please fill in all fields');
                return;
            }

            fetch('/Home/OccupyRoom', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    roomId: parseInt(roomId),
                    studentName: studentName,
                    studentEmail: studentEmail,
                    studentPhone: studentPhone
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Success! ' + data.message);

                    if (data.isFull) {
                        // Room is now full - remove it
                        const roomCard = document.getElementById('room-' + roomId);
                        if (roomCard) {
                            const colDiv = roomCard.closest('.col-md-3');
                            if (colDiv) {
                                colDiv.remove();
                            }
                        }
                    } else {
                        // Update the bed count display
                        const roomCard = document.getElementById('room-' + roomId);
                        if (roomCard) {
                            const statusSpan = roomCard.querySelector('.room-status');
                            if (data.bedsLeft === data.totalBeds) {
                                statusSpan.className = 'room-status status-available';
                                statusSpan.innerHTML = `<i class="fas fa-bed me-1"></i>${data.bedsLeft} beds`;
                            } else {
                                statusSpan.className = 'room-status status-partial';
                                statusSpan.innerHTML = `<i class="fas fa-bed me-1"></i>${data.bedsLeft} left`;
                            }

                            // Update button text
                            const button = roomCard.querySelector('.btn-occupy');
                            button.innerHTML = `<i class="fas fa-check-circle me-2"></i>Occupy Bed (${data.bedsLeft} left)`;
                        }
                    }

                    // Update stats
                    updateStatsAfterBooking();

                    // Hide modal and reset form
                    bookingModal.hide();
                    document.getElementById('bookingForm').reset();
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                alert('Error: ' + error);
            });
        }

        // View all rooms (placeholder for pagination)
        document.getElementById('view-all-rooms')?.addEventListener('click', function(e) {
            e.preventDefault();
            alert('View all rooms feature coming soon!');
        });
    </script>
</body>
</html>
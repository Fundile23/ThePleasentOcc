@{
    ViewData["Title"] = "ThePleasantOcc - Student Residence";
}

<!-- Modern Blue & Grey Theme -->
<style>
    :root {
        --primary-blue: #1e3a8a;
        --secondary-blue: #2563eb;
        --light-blue: #3b82f6;
        --cool-grey: #64748b;
        --light-grey: #94a3b8;
        --soft-grey: #e2e8f0;
        --dark-grey: #334155;
        --white: #ffffff;
        --black: #0f172a;
    }

    body {
        background-color: #f8fafc;
        color: var(--dark-grey);
        overflow-x: hidden;
    }

    h1, h2, h3, h4, h5, h6 {
        color: var(--primary-blue);
    }

    /* Modern Navigation */
    .navbar-modern {
        background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%) !important;
        box-shadow: 0 4px 20px rgba(30, 58, 138, 0.2);
        padding: 15px 0;
        transition: all 0.3s ease;
    }

        .navbar-modern .navbar-brand {
            color: white !important;
            font-weight: 700;
            font-size: 1.8rem;
            letter-spacing: -0.5px;
        }

        .navbar-modern .nav-link {
            color: rgba(255,255,255,0.9) !important;
            font-weight: 500;
            margin: 0 15px;
            transition: all 0.3s ease;
            position: relative;
        }

            .navbar-modern .nav-link::after {
                content: '';
                position: absolute;
                bottom: -5px;
                left: 0;
                width: 0;
                height: 2px;
                background: white;
                transition: width 0.3s ease;
            }

            .navbar-modern .nav-link:hover::after {
                width: 100%;
            }

            .navbar-modern .nav-link:hover {
                color: white !important;
                transform: translateY(-2px);
            }

    /* Modern Hero */
    .hero-modern {
        padding: 140px 0 80px;
        background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
        position: relative;
        overflow: hidden;
    }

        .hero-modern::before {
            content: '';
            position: absolute;
            top: -20%;
            right: -10%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, var(--light-blue) 0%, transparent 70%);
            border-radius: 50%;
            opacity: 0.1;
            animation: pulse 8s ease-in-out infinite;
        }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
            opacity: 0.1;
        }

        50% {
            transform: scale(1.1);
            opacity: 0.15;
        }
    }

    .hero-modern h1 {
        font-size: 3.5rem;
        font-weight: 800;
        color: var(--primary-blue);
        line-height: 1.2;
    }

    .hero-modern .highlight {
        color: var(--secondary-blue);
        position: relative;
        display: inline-block;
    }

    .hero-modern .badge-blue {
        background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
        color: white;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 500;
        display: inline-block;
        margin-bottom: 20px;
        animation: glow 2s ease-in-out infinite;
    }

    @@keyframes glow {
        0%, 100% {
            box-shadow: 0 0 20px rgba(37, 99, 235, 0.3);
        }

        50% {
            box-shadow: 0 0 30px rgba(37, 99, 235, 0.6);
        }
    }

    /* Modern Cards - UPDATED for better images */
    .card-modern {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 1px solid rgba(0,0,0,0.05);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .card-modern:hover {
            transform: translateY(-15px) scale(1.02);
            box-shadow: 0 30px 60px rgba(37, 99, 235, 0.2);
            border-color: var(--light-blue);
        }

    .residence-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        transition: all 0.5s ease;
        display: block;
    }

    .card-modern:hover .residence-img {
        transform: scale(1.08);
    }

    .card-content {
        padding: 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .card-modern .number {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--secondary-blue);
        background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* FIX: Icon alignment */
    .card-content .d-flex.align-items-center {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .card-content .fa-fw {
        width: 24px;
        text-align: center;
        font-size: 1.1rem;
    }

    .card-content small {
        font-size: 0.9rem;
        color: var(--cool-grey);
        line-height: 1.4;
    }

    .label {
        color: var(--cool-grey);
        font-weight: 500;
        font-size: 0.95rem;
        margin-bottom: 15px;
    }

    .badge-available {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        padding: 4px 12px;
        border-radius: 50px;
        font-weight: 500;
        font-size: 0.8rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
        white-space: nowrap;
    }

    .badge-full {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
        padding: 4px 12px;
        border-radius: 50px;
        font-weight: 500;
        font-size: 0.8rem;
        opacity: 0.7;
    }

    .btn-modern {
        background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 50px;
        font-weight: 500;
        transition: all 0.3s ease;
        width: 100%;
        position: relative;
        overflow: hidden;
        z-index: 1;
        margin-top: auto;
        font-size: 0.95rem;
    }

        .btn-modern::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, var(--secondary-blue), var(--light-blue));
            transition: all 0.3s ease;
            z-index: -1;
        }

        .btn-modern:hover::before {
            left: 0;
        }

        .btn-modern:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(37, 99, 235, 0.4);
            color: white;
        }

    .btn-modern-outline {
        background: transparent;
        border: 2px solid var(--secondary-blue);
        color: var(--secondary-blue);
        padding: 10px 25px;
        border-radius: 50px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

        .btn-modern-outline:hover {
            background: var(--secondary-blue);
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(37, 99, 235, 0.2);
        }

    /* ICON CARDS for Amenities */
    .amenity-icon-card {
        background: white;
        border-radius: 20px;
        padding: 30px 20px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
        height: 100%;
    }

        .amenity-icon-card:hover {
            background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
            transform: translateY(-10px);
            border-color: transparent;
            box-shadow: 0 20px 40px rgba(37, 99, 235, 0.3);
        }

        .amenity-icon-card .icon-wrapper {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.1), rgba(30, 58, 138, 0.1));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            transition: all 0.3s ease;
        }

        .amenity-icon-card:hover .icon-wrapper {
            background: white;
            transform: scale(1.1) rotate(5deg);
        }

        .amenity-icon-card .icon-wrapper i {
            font-size: 2.5rem;
            color: var(--primary-blue);
            transition: all 0.3s ease;
        }

        .amenity-icon-card:hover .icon-wrapper i {
            color: var(--primary-blue);
        }

        .amenity-icon-card h3 {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 10px;
            transition: all 0.3s ease;
        }

        .amenity-icon-card:hover h3 {
            color: white;
        }

        .amenity-icon-card p {
            color: var(--cool-grey);
            margin-bottom: 15px;
            font-size: 0.9rem;
            line-height: 1.5;
            transition: all 0.3s ease;
        }

        .amenity-icon-card:hover p {
            color: rgba(255,255,255,0.9);
        }

        .amenity-icon-card .feature-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            justify-content: center;
        }

        .amenity-icon-card .feature-tag {
            background: var(--soft-grey);
            padding: 4px 10px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            transition: all 0.3s ease;
        }

        .amenity-icon-card:hover .feature-tag {
            background: rgba(255,255,255,0.2);
            color: white;
        }

        .amenity-icon-card .feature-tag i {
            color: var(--primary-blue);
            font-size: 0.8rem;
            transition: all 0.3s ease;
        }

        .amenity-icon-card:hover .feature-tag i {
            color: white;
        }

    /* Room Detail Icons */
    .room-detail-icon {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        background: var(--soft-grey);
        border-radius: 50px;
        font-size: 0.8rem;
        color: var(--dark-grey);
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }

        .room-detail-icon i {
            color: var(--primary-blue);
            font-size: 0.85rem;
            transition: all 0.3s ease;
        }

        .room-detail-icon:hover {
            background: var(--primary-blue);
            color: white;
            transform: translateY(-2px);
        }

            .room-detail-icon:hover i {
                color: white;
            }

    /* Section Titles */
    .section-title-modern {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--primary-blue);
        margin-bottom: 20px;
        position: relative;
        display: inline-block;
    }

        .section-title-modern::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 80px;
            height: 4px;
            background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
            border-radius: 2px;
            transition: width 0.3s ease;
        }

        .section-title-modern:hover::after {
            width: 120px;
        }

        .section-title-modern.text-center::after {
            left: 50%;
            transform: translateX(-50%);
        }

    /* Stats Section */
    .stats-modern {
        background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
        padding: 60px 0;
        color: white;
        position: relative;
        overflow: hidden;
    }

        .stats-modern::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -20%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            border-radius: 50%;
            animation: float 10s ease-in-out infinite;
        }

    @@keyframes float {
        0%, 100% {
            transform: translate(0, 0);
        }

        50% {
            transform: translate(20px, 20px);
        }
    }

    .stat-item-modern {
        text-align: center;
        position: relative;
        z-index: 2;
    }

        .stat-item-modern .number {
            font-size: 2.5rem;
            font-weight: 700;
            color: white;
            margin-bottom: 5px;
            text-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        .stat-item-modern .label {
            color: rgba(255,255,255,0.9);
            font-size: 1rem;
            font-weight: 500;
        }

    /* Amenities Tags */
    .amenity-tag {
        display: inline-block;
        padding: 6px 14px;
        background: var(--soft-grey);
        border-radius: 50px;
        color: var(--dark-grey);
        font-weight: 500;
        margin: 3px;
        transition: all 0.3s ease;
        border: 1px solid transparent;
        font-size: 0.9rem;
    }

        .amenity-tag i {
            color: var(--secondary-blue);
            margin-right: 5px;
            transition: all 0.3s ease;
        }

        .amenity-tag:hover {
            background: var(--secondary-blue);
            color: white;
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3);
        }

            .amenity-tag:hover i {
                color: white;
            }

    /* Form Controls */
    .form-control-lg, .form-select-lg {
        border: 2px solid var(--soft-grey);
        border-radius: 15px;
        padding: 12px 15px;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

        .form-control-lg:focus, .form-select-lg:focus {
            border-color: var(--secondary-blue);
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
            outline: none;
        }

    /* Footer */
    .footer a {
        transition: all 0.3s ease;
        display: inline-block;
    }

        .footer a:hover {
            transform: translateY(-3px) scale(1.1);
            color: var(--secondary-blue) !important;
        }

    /* Contact icons */
    .contact-icon-wrapper {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.1), rgba(30, 58, 138, 0.1));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: var(--primary-blue);
        transition: all 0.3s ease;
        flex-shrink: 0;
    }

    .contact-item:hover .contact-icon-wrapper {
        background: linear-gradient(135deg, var(--primary-blue), var(--secondary-blue));
        color: white;
        transform: scale(1.1);
    }

    .contact-item {
        transition: all 0.3s ease;
    }

    /* FIX: Badge and title alignment */
    .d-flex.justify-content-between {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
    }

    /* FIX: Icon text alignment */
    .card-content .d-flex.align-items-center {
        display: flex;
        align-items: center;
    }

    /* FIX: Room badges wrap */
    .d-flex.gap-2 {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin: 15px 0;
    }
</style>

<!-- Add AOS CSS -->
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<!-- Modern Navigation -->
<nav class="navbar navbar-expand-lg navbar-modern fixed-top">
    <div class="container">
        <a class="navbar-brand" href="#">
            <i class="fas fa-building me-2"></i>ThePleasantOcc
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="#home">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#residences">Residences</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#amenities">Amenities</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#contact">Contact</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<!-- Modern Hero Section -->
<section class="hero-modern" id="home">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6" data-aos="fade-right" data-aos-duration="1000">

                        <!-- Room Details with Icons - FIXED ALIGNMENT -->
                        <div class="mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-wifi text-primary me-2 fa-fw"></i>
                                <small>Free WiFi</small>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-utensils text-primary me-2 fa-fw"></i>
                                <small>3 Kitchens per floor</small>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-shower text-primary me-2 fa-fw"></i>
                                <small>4 Bathrooms per floor</small>
                            </div>
                        </div>

                        <!-- Room Type Badges with Icons -->
                        <div class="d-flex gap-2 mb-3 flex-wrap">
                            <span class="room-detail-icon"><i class="fas fa-bed"></i> 1 Bed</span>
                            <span class="room-detail-icon"><i class="fas fa-user"></i> Private</span>
                            <span class="room-detail-icon"><i class="fas fa-snowflake"></i> AC</span>
                            <span class="room-detail-icon"><i class="fas fa-desk"></i> Study Desk</span>
                        </div>

                        <a href="@Url.Action("ResidenceDetails", "Home", new { residence = "single" })" class="btn-modern">
                            <i class="fas fa-eye me-2"></i>View Single Rooms
                        </a>
                    </div>
                </div>
            </div>

            <!-- Residence B - The Double - FIXED: New working image URL -->
            <div class="col-lg-3 col-md-6" data-aos="flip-left" data-aos-duration="800" data-aos-delay="200">
                <div class="card-modern">
                    <img src="~/images/IMG_3849.JPG" alt="Double Room Student Residence" class="residence-img">
                    <div class="card-content">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="number">The Double</div>
                            <span class="badge-available"><i class="fas fa-check-circle"></i> Available</span>
                        </div>
                        <div class="label mb-3"><i class="fas fa-users me-2"></i>128 Students • <i class="fas fa-layer-group me-1"></i>4 Floors</div>

                        <!-- Room Details with Icons - FIXED ALIGNMENT -->
                        <div class="mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-wifi text-primary me-2 fa-fw"></i>
                                <small>Free WiFi</small>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-utensils text-primary me-2 fa-fw"></i>
                                <small>3 Kitchens per floor</small>

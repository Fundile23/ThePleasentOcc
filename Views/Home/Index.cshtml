                <!-- Amenities Preview with Icons -->
                <div class="d-flex gap-3 mb-4 flex-wrap" data-aos="fade-up" data-aos-delay="800">
                    <span class="amenity-tag"><i class="fas fa-wifi"></i> Free WiFi</span>
                    <span class="amenity-tag"><i class="fas fa-swimmer"></i> Swimming Pool</span>
                    <span class="amenity-tag"><i class="fas fa-tree"></i> Park Fields</span>
                    <span class="amenity-tag"><i class="fas fa-dumbbell"></i> Gym Access</span>
                    <span class="amenity-tag"><i class="fas fa-shield-alt"></i> 24/7 Security</span>
                    <span class="amenity-tag"><i class="fas fa-bus"></i> Shuttle</span>
                </div>

                <div class="d-flex gap-3" data-aos="fade-up" data-aos-delay="1000">
                    <a href="#residences" class="btn-modern">Browse Residences</a>
                    <a href="#amenities" class="btn-modern-outline">Explore Amenities</a>
                </div>
            </div>
            <div class="col-lg-6 text-center" data-aos="fade-left" data-aos-duration="1000" data-aos-delay="200">
                <img src="~/images/IMG_3848.JPG" alt="Student Residence" class="img-fluid rounded-4 shadow-lg" style="animation: float 6s ease-in-out infinite;">
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="stats-modern">
    <div class="container">
        <div class="row">
            <div class="col-md-3 col-6 mb-4 mb-md-0" data-aos="zoom-in" data-aos-duration="800" data-aos-delay="100">
                <div class="stat-item-modern">
                    <div class="number">492+</div>
                    <div class="label">Happy Students</div>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-4 mb-md-0" data-aos="zoom-in" data-aos-duration="800" data-aos-delay="200">
                <div class="stat-item-modern">
                    <div class="number">4</div>
                    <div class="label">Modern Residences</div>
                </div>
            </div>
            <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-duration="800" data-aos-delay="300">
                <div class="stat-item-modern">
                    <div class="number">24/7</div>
                    <div class="label">Security</div>
                </div>
            </div>
            <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-duration="800" data-aos-delay="400">
                <div class="stat-item-modern">
                    <div class="number">5★</div>
                    <div class="label">Amenities</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Residences Section with REALISTIC STUDENT PICTURES and ICONS -->
<section class="py-5" id="residences">
    <div class="container">
        <h2 class="section-title-modern text-center mb-5" data-aos="fade-up" data-aos-duration="800">Our Residences</h2>
